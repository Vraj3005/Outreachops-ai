# Supabase Configuration
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Gemini AI API Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_LIST=gemini-2.5-flash-lite,gemini-2.5-flash

# Google Sheets Configuration
GOOGLE_SHEET_NAME=pitbull-cold-emails-calls
MAIN_TAB_NAME=Demo
DRAFT_TAB_NAME=Email Demo Drafts
SHEETS_CREDENTIALS_PATH=sheets_credentials.json

# Gmail API Configuration (OAuth Flow)
GMAIL_CREDENTIALS_PATH=gmail_credentials.json
GMAIL_TOKEN_PATH=gmail_token.pkl

# Agency Branding (used as email signatures)
YOUR_AGENCY_NAME=Pitbull Corporations
YOUR_WEBSITE=https://pitbullcorporations.com
YOUR_NAME=Vraj
YOUR_PHONE=

# Safety & Rate Limits
DAILY_SEND_LIMIT=50
SEND_DELAY_SECONDS=60
BATCH_SIZE=5

# Run in Demo Mode without requiring active sheets/gmail API keys/tokens
DEMO_MODE=true

# Application Port
PORT=8000
